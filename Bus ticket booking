# Bus Ticket Booking System

total_seats = 20
booked_seats = []

while True:
    print("\n===== BUS TICKET BOOKING SYSTEM =====")
    print("1. View Available Seats")
    print("2. Book Ticket")
    print("3. View Booked Seats")
    print("4. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        available = total_seats - len(booked_seats)
        print(f"Available Seats: {available}")

    elif choice == "2":
        name = input("Enter Passenger Name: ")
        seat_no = int(input("Enter Seat Number (1-20): "))

        if seat_no < 1 or seat_no > total_seats:
            print("Invalid seat number!")

        elif seat_no in booked_seats:
            print("Seat already booked!")

        else:
            booked_seats.append(seat_no)
            print("\n===== TICKET BOOKED SUCCESSFULLY =====")
            print(f"Passenger Name: {name}")
            print(f"Seat Number: {seat_no}")

    elif choice == "3":
        print("Booked Seats:", sorted(booked_seats))

    elif choice == "4":
        print("Thank you for using the Bus Ticket Booking System!")
        break

    else:
        print("Invalid choice. Please try again.")